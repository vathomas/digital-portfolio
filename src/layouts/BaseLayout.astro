---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import { APP_VERSION } from '../lib/version';

interface Props {
  title: string;
  description?: string;
  /**
   * Path to the OG image, relative to the site root. Resolved against
   * `Astro.site` so it ends up absolute in the rendered tag — most social
   * platforms reject relative URLs.
   */
  ogImage?: string;
  /**
   * Override the canonical URL. Defaults to the current page's URL.
   * Useful if you want a project page's canonical to point elsewhere.
   */
  canonicalUrl?: string;
}

const DEFAULT_DESCRIPTION =
  'Thomas Abraham — Full-Stack Product Engineer & Agentic AI Builder. ' +
  '10+ years building scalable systems. Now building AI that thinks, ' +
  'acts, and self-corrects.';

const {
  title,
  description = DEFAULT_DESCRIPTION,
  ogImage = '/og-default.png',
  canonicalUrl,
} = Astro.props;

// Astro.site is set in astro.config.mjs. If it's missing for some reason,
// fall back to a relative URL — better than throwing during render.
const siteUrl = Astro.site;
const ogImageAbs = siteUrl ? new URL(ogImage, siteUrl).href : ogImage;
const canonicalAbs = canonicalUrl
  ? canonicalUrl
  : (siteUrl ? new URL(Astro.url.pathname, siteUrl).href : Astro.url.href);
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalAbs} />
    <title>{title}</title>

    <!-- Open Graph (Facebook, LinkedIn, Slack, Discord, …) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalAbs} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="tvabraham.dev" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />
    <Analytics />
  </head>
  <body class="bg-gray-950 text-gray-100 min-h-screen font-sans antialiased">
    <header class="border-b border-gray-800 px-4 sm:px-6 py-3 sm:py-4 sticky top-0 z-50 bg-gray-950/90 backdrop-blur">
      <nav class="max-w-5xl mx-auto flex items-center justify-between">
        <a href="/" class="text-agent-500 font-bold text-lg tracking-tight font-mono">
          tvabraham<span class="text-gray-500">.dev</span>
        </a>

        {/* Mobile hamburger button — hidden on md+ where the full nav fits */}
        <button
          id="mobile-menu-toggle"
          type="button"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="primary-nav"
          class="md:hidden inline-flex items-center justify-center min-w-[44px] min-h-[44px] -mr-2 text-gray-300 hover:text-agent-400 transition-colors"
        >
          <svg id="mobile-menu-icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="mobile-menu-icon-close" class="hidden w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

        {/*
          Primary nav. On mobile (<md) it's an absolute-positioned dropdown
          panel under the header, hidden by default and toggled by the
          hamburger. On md+ it's a flat row of links to the right of the logo.
        */}
        <ul
          id="primary-nav"
          class="hidden md:flex md:items-center md:gap-6 md:static md:bg-transparent md:border-0 md:p-0 md:shadow-none
                 absolute left-0 right-0 top-full flex-col gap-1 p-3 bg-gray-950/95 backdrop-blur border-t border-gray-800
                 text-sm text-gray-400 shadow-lg"
        >
          <li><a href="/projects" class="block py-2.5 px-2 md:p-0 hover:text-agent-400 transition-colors">Projects</a></li>
          <li><a href="/about" class="block py-2.5 px-2 md:p-0 hover:text-agent-400 transition-colors">About</a></li>
          <li><a href="/certifications" class="block py-2.5 px-2 md:p-0 hover:text-agent-400 transition-colors">Certs</a></li>
          <li><a href="/research" class="block py-2.5 px-2 md:p-0 hover:text-agent-400 transition-colors">Research</a></li>
          <li><a href="/crew" class="block py-2.5 px-2 md:p-0 hover:text-agent-400 transition-colors">Crew</a></li>
          <li><a href="/dashboard" class="block py-2.5 px-2 md:p-0 hover:text-agent-400 transition-colors">Dashboard</a></li>
          <li class="md:ml-0 mt-1 md:mt-0 pt-2 md:pt-0 border-t md:border-0 border-gray-800">
            <a
              href="https://www.linkedin.com/in/tvabraham"
              target="_blank"
              rel="noopener"
              class="block py-2.5 px-2 md:p-0 text-agent-500 hover:text-agent-400 transition-colors font-medium"
            >
              LinkedIn ↗
            </a>
          </li>
        </ul>
      </nav>
    </header>

    <main class="max-w-5xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
      <slot />
    </main>

    <footer class="border-t border-gray-800 px-4 sm:px-6 py-6 sm:py-8 mt-12 sm:mt-16">
      <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-start md:items-center justify-between gap-3 md:gap-4">
        <div class="text-xs sm:text-sm text-gray-500">
          <span class="text-gray-300 font-medium">Thomas Abraham</span>
          &nbsp;·&nbsp; London, UK
          &nbsp;·&nbsp;
          <a href="mailto:ta.abraham@outlook.com" class="break-all hover:text-agent-400 transition-colors">
            ta.abraham@outlook.com
          </a>
        </div>
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 sm:gap-5 text-xs sm:text-sm text-gray-500">
          <a href="https://www.linkedin.com/in/tvabraham" target="_blank" rel="noopener"
             class="hover:text-agent-400 transition-colors">LinkedIn</a>
          <a href="/about" class="hover:text-agent-400 transition-colors">About</a>
          <a href="/certifications" class="hover:text-agent-400 transition-colors">Certifications</a>
          <span class="text-xs text-gray-600 font-mono" title="build version">{APP_VERSION}</span>
        </div>
      </div>
    </footer>

    {/*
      Inline script (is:inline) wires up the hamburger:
       - Toggles the nav panel and swaps the open/close icons
       - Updates aria-expanded so screen readers track state
       - Closes the menu when any link is clicked (mobile only) so a single
         tap navigates without leaving the menu stuck open
      Kept tiny and dependency-free; runs on every page load.
    */}
    <script is:inline>
      (function () {
        const btn = document.getElementById('mobile-menu-toggle');
        const nav = document.getElementById('primary-nav');
        const iconOpen = document.getElementById('mobile-menu-icon-open');
        const iconClose = document.getElementById('mobile-menu-icon-close');
        if (!btn || !nav) return;

        function setOpen(open) {
          nav.classList.toggle('hidden', !open);
          btn.setAttribute('aria-expanded', String(open));
          if (iconOpen) iconOpen.classList.toggle('hidden', open);
          if (iconClose) iconClose.classList.toggle('hidden', !open);
        }

        btn.addEventListener('click', function () {
          const isHidden = nav.classList.contains('hidden');
          setOpen(isHidden);
        });

        nav.querySelectorAll('a').forEach(function (link) {
          link.addEventListener('click', function () {
            if (window.matchMedia('(max-width: 767px)').matches) setOpen(false);
          });
        });
      })();
    </script>
  </body>
</html>
