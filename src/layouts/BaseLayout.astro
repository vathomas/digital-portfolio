---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Thomas Abraham — Full-Stack Product Engineer & Agentic AI Builder. 10+ years building scalable systems. Now building AI that thinks, acts, and self-corrects.' } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-gray-950 text-gray-100 min-h-screen font-sans antialiased">
    <header class="border-b border-gray-800 px-6 py-4 sticky top-0 z-50 bg-gray-950/90 backdrop-blur">
      <nav class="max-w-5xl mx-auto flex items-center justify-between">
        <a href="/" class="text-agent-500 font-bold text-lg tracking-tight font-mono">
          tvabraham<span class="text-gray-500">.dev</span>
        </a>
        <ul class="flex gap-6 text-sm text-gray-400">
          <li><a href="/projects" class="hover:text-agent-400 transition-colors">Projects</a></li>
          <li><a href="/about" class="hover:text-agent-400 transition-colors">About</a></li>
          <li><a href="/certifications" class="hover:text-agent-400 transition-colors">Certs</a></li>
          <li><a href="/research" class="hover:text-agent-400 transition-colors">Research</a></li>
          <li><a href="/crew" class="hover:text-agent-400 transition-colors">Crew</a></li>
          <li><a href="/dashboard" class="hover:text-agent-400 transition-colors">Dashboard</a></li>
          <li>
            <a href="https://www.linkedin.com/in/tvabraham" target="_blank" rel="noopener"
               class="text-agent-500 hover:text-agent-400 transition-colors font-medium">
              LinkedIn ↗
            </a>
          </li>
        </ul>
      </nav>
    </header>

    <main class="max-w-5xl mx-auto px-6 py-12">
      <slot />
    </main>

    <footer class="border-t border-gray-800 px-6 py-8 mt-16">
      <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="text-sm text-gray-500">
          <span class="text-gray-300 font-medium">Thomas Abraham</span>
          &nbsp;·&nbsp; London, UK
          &nbsp;·&nbsp;
          <a href="mailto:ta.abraham@outlook.com" class="hover:text-agent-400 transition-colors">
            ta.abraham@outlook.com
          </a>
        </div>
        <div class="flex gap-5 text-sm text-gray-500">
          <a href="https://www.linkedin.com/in/tvabraham" target="_blank" rel="noopener"
             class="hover:text-agent-400 transition-colors">LinkedIn</a>
          <a href="/about" class="hover:text-agent-400 transition-colors">About</a>
          <a href="/certifications" class="hover:text-agent-400 transition-colors">Certifications</a>
        </div>
      </div>
    </footer>
  </body>
</html>
