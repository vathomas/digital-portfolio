  <p class="text-gray-400 mb-10">
    Watch three specialized agents collaborate: PM → Coder → Reviewer.
    A live flowchart highlights which agent holds the token.
  </p>

  <!-- Phase 2: CrewOrchestrator + AgentFlowChart islands will be mounted here -->
  <div class="rounded-xl border border-dashed border-gray-700 bg-gray-900/50 p-12 text-center text-gray-600 font-mono text-sm">
    [ CrewOrchestrator — Phase 2 ]
  </div>
</BaseLayout>
