---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectFilterBar from '../../components/islands/ProjectFilterBar';
import { getCollection } from 'astro:content';

// Order cards to match the top-menu showcase sequence (1 → 5), then the
// off-site Python prototypes. Any future project not listed sorts to the end.
const SHOWCASE_ORDER = [
  'recursive-portfolio-chatbot', // 1 · Chat
  'deep-research-agent',         // 2 · Research
  'software-architect-crew',     // 3 · Crew
  'agent-playground',            // 4 · Playground
  'agent-skills-dashboard',      // 5 · Dashboard
];
const rank = (id: string) => {
  const i = SHOWCASE_ORDER.indexOf(id);
  return i === -1 ? Number.POSITIVE_INFINITY : i;
};

const projects = (await getCollection('projects')).sort((a, b) => rank(a.id) - rank(b.id));
const projectData = projects.map((p) => ({
  slug: p.id,
  title: p.data.title,
  description: p.data.description,
  techStack: p.data.techStack,
  agentLogicType: p.data.agentLogicType,
  status: p.data.status,
}));
---

<BaseLayout title="Projects — AgentPortfolio">
  <h1 class="text-3xl font-bold text-white mb-2">All Projects</h1>
  <p class="text-gray-400 mb-8">
    Agentic AI systems across five patterns: ReAct, Plan-and-Execute, Multi-Agent, Self-Correcting, and Tool-Use.
    The in-site showcases run interactively on this domain; the Python prototypes are research notebooks.
  </p>

  <ProjectFilterBar projects={projectData} client:idle />
</BaseLayout>
